# IntroFlow .env.example (TEMPLATE ONLY)
# - Do NOT put real secrets here.
# - Copy to .env and fill in real values (never commit .env).
# - All vars use INTROFLOW_ prefix except DATABASE_URL.

# Required: PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/trueferral
# Render example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Required: development or production
APP_ENV=development

# Optional: true = JSON logs (use in production), false = human-readable (use in dev)
INTROFLOW_LOG_JSON=false

# Required in production: generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTROFLOW_SECRET_KEY=dev-secret-key
